{
  "manifest_version": 3,
  "name": "PokeBit - High Entropy Wallet Generator",
  "short_name": "PokeBit",
  "version": "1.0.0",
  "description": "Generate high-entropy BIP-39 seed phrases with derived private keys and public addresses for ETH and BTC. 100% offline, zero data collection.",
  "author": "doctor.bitcoin",
  
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PokeBit Wallet Generator"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "permissions": [],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  
  "offline_enabled": true,
  
  "homepage_url": "https://pokebit.lovable.app/privacy"
}
